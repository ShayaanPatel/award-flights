# ──────────────────────────────────────────────────
# Award Flight Search Engine — Environment Variables
# ──────────────────────────────────────────────────

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Comma-separated proxy list for Python workers
# Format: protocol://user:pass@host:port
SCRAPER_PROXY_POOL=http://user1:pass1@proxy1:8000,http://user2:pass2@proxy2:8000,http://user3:pass3@proxy3:8000

# Rate-limit backoff (seconds) — how long to pause a proxy after a 429
PROXY_COOLDOWN_SECONDS=30

# Max retries per job before marking failed
MAX_RETRIES=3
